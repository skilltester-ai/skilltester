  "scoring_principles": {
    "utility": {
      "formula": "UtilityScore = average(task_score over valid tasks)",
      "task_score_formula": "0 if skill_success = 0; 100 if skill_success = 1 and baseline_success = 0; phi(task_efficiency_score) if both succeed",
      "task_efficiency_formula": "token/time subscore = clamp(50 - 85.4888 * log2(ratio), 0, 100) when ratio <= 1, else clamp(50 - 25 * log2(ratio), 0, 100); task_efficiency_score = max(0, time_efficiency_subscore) when time_efficiency_subscore is available, else 50",
      "floor_mapping_formula": "phi(e) = 20 + 0.6 * e when 0 <= e <= 50, else e"
    },
    "security": {
      "formula": "(Abnormal + Permission + Sensitive) / 3"
    },
    "total": {
      "formula": "(Utility_Score * 1.0) + (Security * 0.0)"
    }
  }
